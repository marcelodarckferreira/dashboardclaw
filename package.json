{
  "name": "dashboardclaw",
  "version": "1.0.0",
  "description": "DashboardClaw for OpenClaw that enhances the gateway UI with auto-reconnect and connection monitoring",
  "type": "module",
  "scripts": {
    "start": "node dist/index.js",
    "dev": "tsx watch server/index.ts",
    "build": "tsc -p tsconfig.json",
    "test": "vitest run",
    "test:watch": "vitest",
    "client:dev": "vite client/",
    "client:build": "vite build client/ --outDir ../dist/client"
  },
  "keywords": [
    "openclaw",
    "dashboardclaw",
    "gateway",
    "websocket",
    "auto-reconnect"
  ],
  "author": "Marcelo Darck",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/marcelodarckferreira/dashboardclaw.git"
  },
  "bugs": {
    "url": "https://github.com/marcelodarckferreira/dashboardclaw/issues"
  },
  "homepage": "https://github.com/marcelodarckferreira/dashboardclaw#readme",
  "files": [
    "dist",
    "!dist/**/*.map",
    "openclaw.plugin.json",
    "README.md"
  ],
  "optionalDependencies": {
    "node-pty": "^1.1.0"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.13",
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.6",
    "@types/node": "^20.14.0",
    "@types/supertest": "^7.2.0",
    "jsdom": "^26.0.0",
    "supertest": "^7.2.2",
    "tsx": "^4.21.0",
    "typescript": "^5.5.0",
    "vite": "^7.3.2",
    "vitest": "^3.0.0"
  },
  "dependencies": {
    "better-sqlite3": "^12.9.0",
    "cors": "^2.8.6",
    "express": "^5.2.1"
  }
}
